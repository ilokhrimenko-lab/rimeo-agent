<Page
    x:Class="RimeoAgent.Views.PairingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="16" Spacing="12" MaxWidth="480">
        <TextBlock Text="Pair iOS App" Style="{StaticResource TitleTextBlockStyle}"/>

        <TextBlock TextWrapping="Wrap" Foreground="Gray">
            Open the Rimeo iOS app → tap the QR icon → scan the code below, or enter the pairing code manually.
        </TextBlock>

        <!-- Pairing code -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8" Padding="16">
            <StackPanel Spacing="8">
                <TextBlock Text="Pairing Code" FontWeight="SemiBold"/>
                <TextBlock x:Name="PairingCodeLabel" FontSize="32" FontWeight="Bold"
                           FontFamily="Consolas" Text="------"/>
                <Button Content="Generate New Code" Click="GenCode_Click" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <!-- QR placeholder -->
        <Border x:Name="QrContainer" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8" Padding="16">
            <StackPanel Spacing="8">
                <TextBlock Text="QR Code" FontWeight="SemiBold"/>
                <Image x:Name="QrImage" Width="200" Height="200" Stretch="Uniform"/>
                <TextBlock x:Name="QrUrlLabel" FontSize="11" Foreground="Gray"
                           TextWrapping="Wrap" IsTextSelectionEnabled="True"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
