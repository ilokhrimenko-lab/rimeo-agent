<Page
    x:Class="RimeoAgent.Views.AccountPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="16" Spacing="12" MaxWidth="520">
        <TextBlock Text="Account" Style="{StaticResource TitleTextBlockStyle}"/>

        <!-- Link status -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
            <StackPanel Spacing="8">
                <TextBlock Text="Cloud Connection" FontWeight="SemiBold"/>
                <TextBlock x:Name="LinkStatusLabel" Foreground="Gray"/>
                <TextBlock x:Name="EmailLabel"      Foreground="Gray" FontSize="12"/>

                <!-- Link form (shown when unlinked) -->
                <StackPanel x:Name="LinkForm" Spacing="8">
                    <TextBlock Text="Enter link token from rimeo.app:" FontSize="12"/>
                    <TextBox x:Name="TokenBox" PlaceholderText="Paste token here…" />
                    <Button Content="Link Account" Click="Link_Click"/>
                </StackPanel>

                <!-- Unlink button (shown when linked) -->
                <Button x:Name="UnlinkBtn" Content="Unlink Account"
                        Click="Unlink_Click" Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <!-- Tunnel -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
            <StackPanel Spacing="8">
                <TextBlock Text="Cloudflare Tunnel" FontWeight="SemiBold"/>
                <TextBlock x:Name="TunnelStatusLabel" Foreground="Gray"/>
                <TextBlock x:Name="TunnelUrlLabel" FontSize="11" Foreground="Gray"
                           TextWrapping="Wrap" IsTextSelectionEnabled="True"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="TunnelStartBtn" Content="Start Tunnel"  Click="TunnelStart_Click"/>
                    <Button x:Name="TunnelStopBtn"  Content="Stop Tunnel"   Click="TunnelStop_Click" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Agent info -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
            <StackPanel Spacing="4">
                <TextBlock Text="Agent Info" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBlock x:Name="AgentIdLabel"   FontSize="11" FontFamily="Consolas" IsTextSelectionEnabled="True"/>
                <TextBlock x:Name="AgentUrlLabel"  FontSize="11" Foreground="Gray" IsTextSelectionEnabled="True"/>
                <TextBlock x:Name="VersionLabel"   FontSize="11" Foreground="Gray"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
